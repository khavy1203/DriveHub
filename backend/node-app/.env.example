PORT=8080

# ── MySQL (bắt buộc cho app) ─────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=userstatus
DB_USERNAME=root
DB_PASSWORD=

# Tùy chọn: alias giống Docker/CI (nếu set thì override cùng tên với DB_*)
# DB_NAME=
# DB_USER=
# DB_PASS=

# ── SQL Server — đồng bộ KQSH (bật khi dùng POST /api/admin/kqsh/sync) ──
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=
# MSSQL_ENCRYPT=false
# MSSQL_TRUST_SERVER_CERTIFICATE=true
# MSSQL_CONNECTION_TIMEOUT_MS=15000
# MSSQL_REQUEST_TIMEOUT_MS=30000

# ── Docker MySQL (chỉ khi chạy stack có service mysql_db) ──
# MYSQL_ROOT_PASSWORD=
# MYSQL_DATABASE=
# MYSQL_USER=
# MYSQL_PASSWORD=

# Email (nodemailer) — dùng để gửi thông tin tài khoản học viên
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your@gmail.com
MAIL_PASS=your_app_password
JWT_SECRET=
BOT_TOKEN=
IPNLTB=
NODE_ENV=

# API-level permissions: run migrations so tables api_endpoint + group_api exist (see 20260330100001-…).
# First server start with empty api_endpoint bootstraps rows from src/config/apiRegistry.js.

REACT_APP_MEZON_CLIENT_ID=
MEZON_CLIENT_SECRET=
REACT_APP_MEZON_REDIRECT_URI=https://127.0.0.1:3000/mezon-callback
# Production: chỉ cần ghi MỘT origin (www hoặc apex); server tự cho phép cặp www ↔ cùng domain
# Ví dụ: CORS_ORIGINS=https://driverhub.io.vn  → vẫn chấp nhận https://www.driverhub.io.vn
CORS_ORIGINS=http://127.0.0.1:3000,https://127.0.0.1:3000

MEZON_TOKEN_URL=https://oauth2.mezon.ai/oauth2/token
MEZON_USERINFO_URL=https://oauth2.mezon.ai/userinfo
MEZON_TIMEOUT_MS=10000
SESSION_TTL_MS=604800000
COOKIE_SECURE=false
DEFAULT_MEZON_USER_GENDER_ID=1
DEFAULT_MEZON_USER_GROUP_ID=3
DEFAULT_MEZON_USER_ACTIVE=1
